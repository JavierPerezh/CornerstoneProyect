# Base de datos PostgreSQL (si tu clave tiene caracteres especiales, aplica URL encoding)
DATABASE_URL=postgresql://postgres:TU_CONTRASENA@localhost:5432/posparto_db

# API de Groq
GROQ_API_KEY=your_groq_api_key_here

# API de OpenAI para Whisper
OPENAI_API_KEY=your_openai_api_key_here

# Secreto interno para validar dispositivos
DEVICE_API_KEY_SECRET=your_device_api_key_secret_here

# Secreto para firmar JWT
JWT_SECRET=your_jwt_secret_here

# Duración del JWT en días
JWT_EXPIRE_DAYS=30

# Entorno de ejecución: development, local, staging, production
ENVIRONMENT=development

# Directorio donde se guardan los audios generados
STATIC_AUDIO_DIR=static/audio
